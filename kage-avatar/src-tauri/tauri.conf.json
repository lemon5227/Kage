{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kage",
  "version": "1.0.0",
  "identifier": "com.wenbo.kage",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "launcher",
        "title": "Kage Launcher",
        "width": 900,
        "height": 650,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "resizable": false,
        "shadow": true,
        "url": "/launcher.html"
      },
      {
        "label": "main",
        "title": "Kage",
        "width": 350,
        "height": 550,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "visible": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self' blob: data:; connect-src 'self' http://127.0.0.1:12345 http://localhost:12345 ws://127.0.0.1:12345; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; worker-src 'self' blob:",
      "capabilities": ["default", "http-localhost"]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../../dist/kage-server/**/*",
      "../../config/**/*",
      "assets/*"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
