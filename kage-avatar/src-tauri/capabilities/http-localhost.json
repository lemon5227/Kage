{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "http-localhost",
    "description": "Allow HTTP requests to local backend API",
  "windows": [
        "launcher",
        "main",
        "settings"
  ],
    "permissions": [
        {
            "identifier": "http:default",
            "allow": [
                {
                    "url": "http://127.0.0.1:12345/*"
                },
                {
                    "url": "http://localhost:12345/*"
                }
            ]
        }
    ]
}
